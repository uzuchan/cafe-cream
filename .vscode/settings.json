        "list.focusAndSelectionOutline": "#d9a066"
    },
    "editor.tokenColorCustomizations": {
        "textMateRules": [
            {
                "name": "Comments",
                "scope": ["comment", "punctuation.definition.comment"],
                "settings": {
                    "fontStyle": "italic",
                    "foreground": "#9E8B7A"
                }
            },
            {
                "name": "Keywords",
                "scope": ["keyword", "storage"],
                "settings": {
                    "foreground": "#8B5A2B"
                }
            },
            {
                "name": "Functions",
                "scope": ["entity.name.function", "support.function"],
                "settings": {
                    "fontStyle": "bold",
                    "foreground": "#A0522D"
                }
            },
            {
                "name": "Strings",
                "scope": "string",
                "settings": {
                    "foreground": "#8B4513"
                }
            },
            {
                "name": "Numbers",
                "scope": ["constant.numeric", "constant.character", "constant"],
                "settings": {
                    "foreground": "#CD853F"
                }
            }
        ]
    }
} 